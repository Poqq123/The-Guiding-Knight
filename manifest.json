{
  "manifest_version": 3,
  "name": "The Guiding Knight",
  "description": "Analyze chess positions from the current page or manual FEN input with an educational on-board study overlay.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "The Guiding Knight",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "permissions": [
    "activeTab",
    "offscreen",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "engine-worker.js",
        "vendor/stockfish.js",
        "vendor/stockfish.wasm"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "shared/settings.js",
        "shared/helpers.js",
        "content/state.js",
        "content/detection.js",
        "content/overlay.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
